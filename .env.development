# Use relative /api so Vite dev server proxies to Spring Boot (see vite.config.ts).
VITE_API_BASE_URL=/api

# Demo OTP (123456) allowed in dev; omit in production unless you set this for staging.
VITE_ALLOW_DEMO_OTP=true

# Optional: Google reCAPTCHA v3 site key for sign-in when backend has rentsafe.recaptcha.enabled=true
# VITE_RECAPTCHA_SITE_KEY=
